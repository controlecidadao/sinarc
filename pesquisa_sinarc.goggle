! ============================================================
!  MINISTÉRIOS PÚBLICOS DE CONTAS — DOMÍNIOS PRÓPRIOS
!  Prioridade máxima: boost=10
! ============================================================

! MPC-AC
$boost=10,site=mpc.tceac.tc.br

! MPC-AM
$boost=10,site=mpc.am.gov.br

! MPC-BA
$boost=10,site=mpc.ba.gov.br

! MPC-DF
