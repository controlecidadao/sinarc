! ============================================================
!  MINISTÉRIOS PÚBLICOS DE CONTAS — SUBPÁGINAS DO TCE
!  Prioridade: boost=8
! ============================================================

! MPC-AL → subpágina do TCE-AL
$boost=8,path=tceal.tc.br/mpc

! MPC-AP → subpágina do TCE-AP
$boost=8,path=tce.ap.gov.br/ministerio-publico

! MPC-CE → subpágina do TCE-CE
$boost=8,path=tce.ce.gov.br/mpc-pagina-inicial

! MPC-GO → subpágina do TCE-GO
$boost=8,path=portal.tce.go.gov.br/ministerio-publico-de-contas

! MPC-MA → subpágina do TCE-MA
$boost=8,path=tcema.tc.br/index.php
$boost=8,site=tcema.tc.br

! MPC-PE → subpágina do TCE-PE
$boost=8,path=tcepe.tc.br/internet/index.php/ministerio-publico-de-contas

! MPC-RJ → subpágina do TCE-RJ
$boost=8,path=tcerj.tc.br/portalnovo/pagina/ministerio-publico-especial

! MPC-SE → subpágina do TCE-SE
$boost=8,path=tce.se.gov.br/mpc

! MPC-TO → subpágina do TCE-TO
$boost=8,path=tceto.tc.br/ministerio-publico-de-contas


